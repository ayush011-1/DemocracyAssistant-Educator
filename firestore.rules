rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Entity Validations
    function isValidComment(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'text', 'createdAt', 'sectionId']) &&
             data.keys().size() >= 5 && data.keys().size() <= 7 &&
             data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.text is string && data.text.size() <= 2000 &&
             data.sectionId is string && data.sectionId.size() <= 50 &&
             data.createdAt == request.time &&
             (!data.keys().hasAny(['parentId']) || (data.parentId is string && data.parentId.size() <= 128)) &&
             (!data.keys().hasAny(['authorAvatar']) || (data.authorAvatar is string && data.authorAvatar.size() <= 500));
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.keys().size() >= 2 && data.keys().size() <= 5 &&
             data.email == request.auth.token.email &&
             data.createdAt == request.time &&
             (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 500));
    }

    // Collection Rules
    match /comments/{commentId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn() && isEmailVerified() && isValidId(commentId) && isValidComment(incoming());
      allow update: if isOwner(existing().authorId) && 
                      isEmailVerified() &&
                      isValidComment(incoming()) && 
                      incoming().authorId == existing().authorId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['text', 'authorName', 'authorAvatar']);
      allow delete: if isOwner(existing().authorId);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && 
                      isValidUserProfile(incoming()) && 
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }
  }
}
